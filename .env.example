# ===== Django Settings =====
SECRET_KEY=your-secret-key-here
DEBUG=False

# ===== Database =====
# For PostgreSQL on Render (comment out to use default SQLite)
# DATABASE_URL=postgres://user:password@host:port/database

# ===== CSRF Security =====
# Update with your Render URL
CSRF_TRUSTED_ORIGINS=https://yourapp.onrender.com,https://www.yourapp.onrender.com

# ===== AWS S3 (for media file storage) =====
# Uncomment if using S3 for media uploads
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ===== Cloudinary (alternative to S3) =====
# Uncomment if using Cloudinary for media
# CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# ===== Razorpay (if using payment integration) =====
# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret

